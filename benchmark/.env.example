# ============================================================================
# FieldSight ASR Benchmark — API credentials
# Copy to ".env" and fill in the keys for the providers you want to test.
# Any provider left blank is shown as "not configured" and skipped gracefully.
# ============================================================================

# ---- LLM-as-judge (reference-free scoring) ---------------------------------
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-sonnet-4-6

# ---- Cartesia (Ink STT) ----------------------------------------------------
# https://docs.cartesia.ai/api-reference/stt/transcribe
CARTESIA_API_KEY=
CARTESIA_VERSION=2025-04-16
CARTESIA_MODEL=ink-whisper

# ---- AWS Transcribe (incumbent baseline) -----------------------------------
# Needs an S3 bucket the creds can read/write. Defaults to the FieldSight bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
AWS_TRANSCRIBE_BUCKET=fieldsight-data-509194952652
AWS_TRANSCRIBE_PREFIX=asr-benchmark/

# ---- Zhipu / z.ai GLM-ASR --------------------------------------------------
# https://docs.z.ai/guides/audio/glm-asr-2512   (limit: wav/mp3, <=25MB, <=30s)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4
ZHIPU_MODEL=glm-asr-2512

# ---- Alibaba DashScope (Qwen3-ASR + Fun-ASR) -------------------------------
# One key powers both Qwen3-ASR-Flash and Fun-ASR recording-file recognition.
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=intl          # intl (Singapore) | cn (Beijing)
QWEN_ASR_MODEL=qwen3-asr-flash # qwen3-asr-flash | qwen3-asr-flash-us
FUNASR_MODEL=fun-asr           # Alibaba Fun-ASR (FunAudioLLM) file recognition

# ---- iFlytek 科大讯飞 语音转写 (LFASR v2) -----------------------------------
# https://www.xfyun.cn/doc/asr/ifasr_new/API.html
XFYUN_APPID=
XFYUN_SECRET_KEY=
