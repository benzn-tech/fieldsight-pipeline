# ============================================================================
# FieldSight ASR Benchmark — API credentials
# Copy to ".env" and fill in the keys for the providers you want to test.
# Any provider left blank is shown as "not configured" and skipped gracefully.
# ============================================================================

# ---- LLM-as-judge (reference-free scoring) ---------------------------------
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-sonnet-4-6

# ---- Cartesia (Ink STT) ----------------------------------------------------
# ink-2 = streaming (WebSocket, default, English); ink-whisper = batch.
# CARTESIA_VERSION only applies to the ink-whisper batch path.
# https://docs.cartesia.ai/build-with-cartesia/models/stt
CARTESIA_API_KEY=
CARTESIA_VERSION=2025-04-16
CARTESIA_MODEL=ink-2           # ink-2 (streaming) | ink-whisper (batch)

# ---- ElevenLabs (Scribe STT) -----------------------------------------------
# Scribe v2: 90+ languages, auto-detect, word timestamps + speaker diarization.
# https://elevenlabs.io/docs/api-reference/speech-to-text/convert
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2     # scribe_v2 (latest batch) | scribe_v1

# ---- Plaud (Transcription API) ---------------------------------------------
# Transcription API auth = X-Client-Id + X-Client-Api-Key. The API key is created
# in the Plaud portal (App Settings -> API Keys) and is NOT the client secret.
# The WAV is handed to Plaud as a URL: presigned via your S3 (needs AWS creds) or
# uploaded through Plaud (needs PLAUD_SECRET_KEY). https://docs.plaud.ai
PLAUD_CLIENT_ID=
PLAUD_API_KEY=
PLAUD_SECRET_KEY=                                             # only for Plaud's own file upload
PLAUD_REGION_HOST=https://platform-us.plaud.ai/developer/api  # US | https://platform-jp.plaud.ai/developer/api (Japan)
PLAUD_MODEL=plaud-fast-whisper

# ---- AWS Transcribe (incumbent baseline) -----------------------------------
# Needs an S3 bucket the creds can read/write. Defaults to the FieldSight bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
AWS_TRANSCRIBE_BUCKET=fieldsight-data-509194952652
AWS_TRANSCRIBE_PREFIX=asr-benchmark/

# ---- Zhipu / z.ai GLM-ASR --------------------------------------------------
# https://docs.z.ai/guides/audio/glm-asr-2512   (limit: wav/mp3, <=25MB, <=30s)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4
ZHIPU_MODEL=glm-asr-2512

# ---- Alibaba DashScope (Qwen3-ASR + Fun-ASR) -------------------------------
# One key powers both Qwen3-ASR-Flash and Fun-ASR recording-file recognition.
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=intl          # intl (Singapore) | cn (Beijing)
QWEN_ASR_MODEL=qwen3-asr-flash # qwen3-asr-flash | qwen3-asr-flash-us
FUNASR_MODEL=fun-asr           # Alibaba Fun-ASR (FunAudioLLM) file recognition
